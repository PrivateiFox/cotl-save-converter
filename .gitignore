# Pyenv
#   For a library or package, you might want to ignore it during development
#   but it's often kept in the root for project-specific versions.
# .python-version

# pipenv
#   According to pypa/pipenv#1181, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if participants see overly frequent updates of Pipfile.lock,
#   they can apply it to .gitignore.
# Pipfile.lock

# poetry
#   Similar to Pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# uv
#   uv recommendation is to commit uv.lock.
# uv.lock

# PEP 582; used by e.g. github.com/pypa/python-packages-directory
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

